// ============================================================
// 단평GO — Prisma Schema
// Next.js 15 + Neon Postgres + Clerk
// 설계 원칙:
//  1) Question 은 Test 와 분리하여 영구 저장 → 재사용/문제은행
//  2) 학생은 로그인 없음 → Classroom 코드 + 이름 기반 익명 Attempt
//  3) 교육과정 트리(Subject→Unit)는 확장 가능하게 코드 기반
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Neon: 마이그레이션용 직결 URL
}

// ----------------------------------------------------------
// 사용자 (교사 중심. Clerk 의 userId 를 그대로 매핑)
// 학생은 User 가 아니라 Attempt 로만 존재 (익명 응시)
// ----------------------------------------------------------
enum Role {
  TEACHER
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique // Clerk 의 user id
  email     String?  @unique
  name      String?
  role      Role     @default(TEACHER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classrooms  Classroom[]
  questions   Question[]
  tests       Test[]
  aiUsageLogs AiUsageLog[]

  @@index([clerkId])
}

// ----------------------------------------------------------
// 교육과정 트리: 과목 → 단원
// MVP: 3학년 수학만 시드. grade/term 으로 확장 대비.
// ----------------------------------------------------------
model Subject {
  id        String   @id @default(cuid())
  name      String // 예: "수학"
  grade     Int // 예: 3
  createdAt DateTime @default(now())

  units Unit[]

  @@unique([name, grade])
}

model Unit {
  id           String   @id @default(cuid())
  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  term         Int // 1 또는 2 (학기)
  order        Int // 단원 순서
  name         String // 예: "곱셈"
  // 2022 개정 교육과정 성취기준 코드/설명 → AI 프롬프트 컨텍스트로 사용
  achievementStandard String? @db.Text
  // AI 문항 생성 제약 — 화면에서 편집 가능. null 이면 ai-shared.ts 기본값 사용.
  constraints  String?  @db.Text
  // soft-delete: 기존 문항이 있는 단원을 실수로 삭제하는 것 방지
  isArchived   Boolean  @default(false)

  questions Question[]

  @@unique([subjectId, term, order])
  @@index([subjectId])
}

// ----------------------------------------------------------
// 문항 (영구 저장 = 문제은행). Test 와 분리.
// AI 생성 후 교사가 검수/수정 → isReviewed 로 추적
// ----------------------------------------------------------
enum QuestionType {
  MULTIPLE_CHOICE // 객관식 4지선다
  SHORT_ANSWER // 단답형
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionSource {
  AI // AI 생성
  MANUAL // 교사 직접 작성
}

model Question {
  id          String         @id @default(cuid())
  unitId      String
  unit        Unit           @relation(fields: [unitId], references: [id])
  authorId    String // 생성/소유 교사
  author      User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  type        QuestionType
  difficulty  Difficulty     @default(MEDIUM)
  source      QuestionSource @default(AI)

  stem        String   @db.Text // 문제 본문
  explanation String?  @db.Text // 해설
  // 단답형 정답 키워드(매칭용). 객관식은 Choice.isCorrect 사용
  answerKeywords String[] @default([])

  isReviewed  Boolean  @default(false) // 교사 최종 검수 여부
  isArchived  Boolean  @default(false) // 문제은행 보관(soft delete)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  choices       Choice[]
  testQuestions TestQuestion[]

  @@index([unitId])
  @@index([authorId])
}

model Choice {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  order      Int // 보기 순서 1~4
  text       String   @db.Text
  isCorrect  Boolean  @default(false)

  @@index([questionId])
}

// ----------------------------------------------------------
// 테스트(시험지): 교사가 문항을 조립. 문항은 참조만(복제X).
// ----------------------------------------------------------
enum TestStatus {
  DRAFT // 작성 중
  PUBLISHED // 배포(진행 중)
  CLOSED // 마감
}

model Test {
  id          String     @id @default(cuid())
  ownerId     String
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  classroomId String?
  classroom   Classroom? @relation(fields: [classroomId], references: [id])

  title        String
  status       TestStatus @default(DRAFT)
  timeLimitMin Int? // 시간 제한(분). null = 무제한
  shuffle      Boolean    @default(false) // 문제 순서 랜덤
  shareToken   String     @unique @default(cuid()) // 링크 공유용 토큰
  // 구두 전달·직접 타이핑용 단축 코드 (배포 시 발급). null = 미배포/미발급
  shortCode    String?    @unique

  publishedAt DateTime?
  closedAt    DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  questions TestQuestion[]
  attempts  Attempt[]

  @@index([ownerId])
  @@index([shareToken])
  @@index([shortCode])
}

// 테스트 ↔ 문항 (다대다 + 순서/배점)
model TestQuestion {
  id         String   @id @default(cuid())
  testId     String
  test       Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  order      Int
  points     Int      @default(1)

  answers Answer[]

  @@unique([testId, questionId])
  @@index([testId])
}

// ----------------------------------------------------------
// 클래스(반): 클래스 코드로 학생 초대
// ----------------------------------------------------------
model Classroom {
  id        String   @id @default(cuid())
  teacherId String
  teacher   User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  name      String // 예: "3학년 2반"
  code      String   @unique // 학생 입장용 코드 (예: "X7K2")
  createdAt DateTime @default(now())

  tests    Test[]
  attempts Attempt[]

  @@index([teacherId])
  @@index([code])
}

// ----------------------------------------------------------
// 응시 기록: 학생 = 익명(이름만). User FK 없음.
// ----------------------------------------------------------
enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
}

model Attempt {
  id          String     @id @default(cuid())
  testId      String
  // 교사가 Test를 삭제하면 응시 기록도 함께 삭제된다 (교사용 삭제 기능의 전제조건)
  test        Test       @relation(fields: [testId], references: [id], onDelete: Cascade)
  classroomId String?
  classroom   Classroom? @relation(fields: [classroomId], references: [id])

  studentName String // 학생이 입력한 이름
  status      AttemptStatus @default(IN_PROGRESS)
  score       Int? // 자동 채점 총점
  maxScore    Int? // 만점
  startedAt   DateTime   @default(now())
  submittedAt DateTime?

  answers Answer[]

  @@index([testId])
  @@index([classroomId])
}

model Answer {
  id             String       @id @default(cuid())
  attemptId      String
  attempt        Attempt      @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  testQuestionId String
  // ON DELETE RESTRICT였다면 Test 삭제 시 TestQuestion 캐스케이드 삭제가
  // (Answer가 아직 남아있다는 이유로) 즉시 실패할 수 있어 Cascade로 변경
  testQuestion   TestQuestion @relation(fields: [testQuestionId], references: [id], onDelete: Cascade)

  // 객관식: 선택한 Choice id / 단답형: 입력 텍스트
  selectedChoiceId String?
  textAnswer       String?  @db.Text
  isCorrect        Boolean? // 채점 결과
  earnedPoints     Int      @default(0)

  @@unique([attemptId, testQuestionId])
  @@index([attemptId])
}

// ----------------------------------------------------------
// AI 사용량 로그 — 비용 방어·관리자 모니터링용 (작업 A)
// ----------------------------------------------------------
model AiUsageLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  unitId        String?
  model         String   @default("claude-sonnet-4-6")
  questionCount Int
  questionType  String
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
}

// 운영 알림 중복 방지 — (key, day) 유니크로 하루 1회만 발송
model OpsAlertDay {
  id        String   @id @default(cuid())
  key       String // 예: "ai_global_80"
  day       String // Asia/Seoul 기준 YYYY-MM-DD
  createdAt DateTime @default(now())

  @@unique([key, day])
  @@index([key])
}

// 공개 데모 AI 사용량 — 계정 없이 호출되므로 IP 해시로 추적 (AiUsageLog와 분리)
model DemoAiUsageLog {
  id            String   @id @default(cuid())
  ipHash        String
  unitId        String?
  model         String   @default("claude-sonnet-4-6")
  questionCount Int
  questionType  String
  createdAt     DateTime @default(now())

  @@index([ipHash, createdAt])
  @@index([createdAt])
}

// 6자리 shortCode 브루트포스 완화 — IP(해시)별 최근 시도 기록
model PlayCodeAttempt {
  id        String   @id @default(cuid())
  ipHash    String
  createdAt DateTime @default(now())

  @@index([ipHash, createdAt])
}
