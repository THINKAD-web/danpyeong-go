# ============================================================
# 단평GO 환경변수 예시
# 이 파일을 복사해서 .env.local 로 만들고 실제 값을 채우세요:
#   cp .env.example .env.local
# ⚠️ .env.local 및 실제 키는 절대 커밋하지 마세요 (.gitignore 로 제외됨).
# 현재 스캐폴드는 mock 상태라 값이 없어도 모든 화면이 동작합니다.
# 아래 변수는 mock → 실제 연결 단계에서 채웁니다.
# ============================================================

# --- 데이터베이스 (Neon Postgres + Prisma) ---
# DATABASE_URL: 앱 런타임용 (pooled 연결)
# DIRECT_URL:   prisma migrate 용 직결(non-pooled) 연결
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# --- 인증 (Clerk — 교사 TEACHER/ADMIN 전용. 학생은 로그인 없음) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# Clerk Dashboard → Webhooks → Signing Secret (Vercel 환경변수에 직접 등록, 커밋 금지)
CLERK_WEBHOOK_SECRET="whsec_..."

# --- AI 문항 생성 (TASK 0 에서 모델 확정 후 해당 키만 사용) ---
# Claude (Anthropic) 사용 시:
ANTHROPIC_API_KEY="sk-ant-..."
# Grok (xAI) 사용 시:
XAI_API_KEY="xai-..."

# --- Vercel Cron (학기 익명화 배치) ---
# Vercel이 Cron 호출 시 Authorization: Bearer <CRON_SECRET> 으로 전달
CRON_SECRET="your-random-cron-secret"
